{
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(curl -s -o NUL -w \"%{http_code}\" http://127.0.0.1:8000/api/dashboard/)",
      "Bash(curl -s http://127.0.0.1:8000/api/dashboard/)",
      "Bash(curl -s -o NUL -w \"page: %{http_code}\\\\nstyles: \" http://127.0.0.1:8000/)",
      "Bash(curl -s -o NUL -w \"%{http_code}\\\\napp.js: \" http://127.0.0.1:8000/static/styles.css)",
      "Bash(curl -s -o NUL -w \"%{http_code}\\\\n\" http://127.0.0.1:8000/static/app.js)",
      "Bash(curl -s http://127.0.0.1:8000/)",
      "Bash(curl *)"
    ]
  }
}
